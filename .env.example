# Copy to .env and fill in. .env is gitignored — never commit real keys.

# --- LLM provider: start local, switch later with one flag ---
LLM_PROVIDER=ollama            # "ollama" (local, free) or "anthropic" (API)

# Ollama — local prototyping, free, runs on your machine
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_JUDGE_MODEL=llama3.1:8b

# Anthropic API — fill in when you set LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_JUDGE_MODEL=claude-haiku-4-5-20251001   # cheaper model for grading/judging

# --- Local services ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=variant_audit
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Observability (Week 3+) ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=variant-audit

# --- Optional / later ---
# HUGGINGFACE_TOKEN=          # only needed for gated models; default embeddings need no token
# AWS_PROFILE=                # only if you deploy to EKS (Week 4+)
